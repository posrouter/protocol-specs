{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://posrouter.com/schemas/payment-request-v1.5.json",
  "title": "PaymentRequest",
  "type": "object",
  "required": ["terminalId", "orderId", "attemptId", "merchantId", "amount", "currency"],
  "properties": {
    "terminalId": { "type": "string" },
    "orderId": { "type": "string" },
    "attemptId": { "type": "string" },
    "merchantId": { "type": "string", "description": "Merchant id; with acquirerCode and subMerchantId forms NATS subject namespace" },
    "acquirerCode": { "type": "string" },
    "subMerchantId": { "type": "string", "description": "Omitted on NATS subject as _ when absent" },
    "amount": { "type": "integer" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "targetPackageName": { "type": "string" },
    "targetScheme": { "type": "string" },
    "metadata": { "type": "object" }
  }
}
