{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaymentResult",
  "type": "object",
  "required": ["terminalId", "status", "amount", "currency"],
  "properties": {
    "terminalId": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["approved", "declined", "cancelled", "error"]
    },
    "transactionId": { "type": "string" },
    "amount": { "type": "integer" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "message": { "type": "string" }
  }
}
